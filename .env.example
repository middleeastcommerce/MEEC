# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_deployer_wallet_private_key_here

# Alchemy RPC URLs
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API key for source verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Token initial supply in wei (100 Billion tokens with 18 decimals)
INITIAL_SUPPLY=100000000000000000000000000000

# Enable gas cost reporting in tests (set to "true" to enable)
REPORT_GAS=false
